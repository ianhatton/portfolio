%footer{ role: "contentinfo" }
  .wrap
    .padding
      %section.social
        %h1.zeta.bold-weight.accent
          Elsewhere
        %ul
          %li= link_to content_tag(:span, "GitHub", class: "hidden"), "https://github.com/ianhatton", class: "github external-link", target: "_blank", rel: "noopener noreferrer"
          %li= link_to content_tag(:span, "LinkedIn", class: "hidden"), "https://uk.linkedin.com/in/ian-hatton", class: "linkedin external-link", target: "_blank", rel: "noopener noreferrer"
          %li= link_to content_tag(:span, "NPM", class: "hidden"), "https://www.npmjs.com/~ianhatton", class: "npm external-link", target: "_blank", rel: "noopener noreferrer"

