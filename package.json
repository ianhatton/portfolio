{
  "name": "gulp-starter",
  "version": "3.1.0",
  "description": "A full featured configurable gulp asset pipeline and static site builder",
  "engines": {
    "node": ">=0.12.0 ~5.9.0",
    "npm": ">=2.14.12 ~3.7.3"
  },
  "eslintConfig": {
    "env": {
      "es6": true
    },
    "extends": "morsedigital",
    "globals": {
      "fdescribe": true,
      "describe": false,
      "beforeEach": false,
      "afterEach": false,
      "it": true,
      "I18n": true,
      "expect": true,
      "spyOn": true
    },
    "rules": {
      "require-jsdoc": 0
    }
  },
  "homepage": "http://code.viget.com/gulp-starter/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/vigetlabs/gulp-starter.git"
  },
  "scripts": {
    "start": "gulp",
    "gulp": "gulp",
    "development": "gulp",
    "production": "gulp production",
    "deploy": "gulp deploy",
    "demo": "gulp production && gulp server",
    "test": "gulp production && karma start --single-run",
    "test:watch": "karma start",
    "test:gulp": "mocha ./gulpfile.js/**/*.test.js"
  },
  "devDependencies": {
    "babel-core": "6.21.0",
    "babel-loader": "6.2.10",
    "babel-preset-es2015": "6.18.0",
    "babel-preset-stage-1": "6.16.0",
    "browser-sync": "2.18.5",
    "chai": "3.5.0",
    "compression": "1.6.2",
    "del": "2.2.2",
    "eslint": "^3.12.2",
    "eslint-config-google": "^0.7.1",
    "eslint-config-morsedigital": "1.1.0",
    "eslint-plugin-jasmine": "^2.2.0",
    "express": "4.14.0",
    "gulp": "3.9.1",
    "gulp-autoprefixer": "3.1.1",
    "gulp-changed": "1.3.2",
    "gulp-cssnano": "2.1.2",
    "gulp-data": "1.2.1",
    "gulp-gh-pages": "0.5.4",
    "gulp-htmlmin": "3.0.0",
    "gulp-iconfont": "8.0.1",
    "gulp-if": "2.0.2",
    "gulp-imagemin": "3.1.1",
    "gulp-notify": "2.2.0",
    "gulp-nunjucks-render": "2.0.0",
    "gulp-rename": "1.2.2",
    "gulp-rev": "7.1.2",
    "gulp-rev-napkin": "0.1.0",
    "gulp-rev-replace": "0.4.3",
    "gulp-sass": "3.0.0",
    "gulp-sequence": "0.4.6",
    "gulp-sizereport": "1.2.0",
    "gulp-sourcemaps": "1.9.1",
    "gulp-svgstore": "6.1.0",
    "gulp-uglify": "2.0.0",
    "gulp-util": "3.0.7",
    "gulp-watch": "4.3.11",
    "karma": "1.3.0",
    "karma-chrome-launcher": "2.0.0",
    "karma-cli": "1.0.1",
    "karma-firefox-launcher": "1.0.0",
    "karma-mocha": "1.3.0",
    "karma-nyan-reporter": "0.2.4",
    "karma-sinon-chai": "1.2.4",
    "karma-webpack": "1.8.0",
    "lodash": "4.17.2",
    "lolex": "1.5.2",
    "mocha": "3.2.0",
    "morgan": "1.7.0",
    "object-assign": "4.1.0",
    "open": "0.0.5",
    "pretty-hrtime": "1.0.3",
    "require-dir": "0.3.1",
    "sinon": "1.17.6",
    "sinon-chai": "2.8.0",
    "webpack": "1.14.0",
    "webpack-dev-middleware": "1.9.0",
    "webpack-hot-middleware": "2.13.2"
  },
  "dependencies": {
    "@ianhatton/vanilla-tabbed-content": "^1.0.0",
    "bourbon": "^4.2.7",
    "breakpoint-sass": "^2.7.0",
    "lwip": "0.0.9",
    "sprity": "^1.0.8",
    "sprity-lwip": "^1.0.7",
    "sprity-sass": "^1.0.4",
    "susy": "^2.2.12",
    "viewport-detection-es6": "^2.0.2"
  }
}
